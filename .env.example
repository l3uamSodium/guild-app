# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@localhost:5432/guild_db"

# ─── Auth.js (NextAuth) ──────────────────────────────────────
AUTH_SECRET="your-secret-here"            # generate: openssl rand -base64 32
AUTH_URL="http://localhost:3000"          # ใช้ชื่อตัวแปรใหม่ของ Auth.js v5

# ─── Discord OAuth ───────────────────────────────────────────
AUTH_DISCORD_ID="your-discord-client-id"
AUTH_DISCORD_SECRET="your-discord-client-secret"

# ─── Discord Bot (สำหรับ DM Notifications) ──────────────────
DISCORD_BOT_TOKEN="your-bot-token"

# ─── Discord Webhook (สำหรับ Season Recap) ──────────────────
DISCORD_WEBHOOK_URL="your-webhook-url"
