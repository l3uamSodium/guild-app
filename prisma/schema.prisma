// prisma/schema.prisma
// Prisma 7 — provider = "prisma-client", output required

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Required Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  discordId     String?   @unique

  accounts Account[]
  sessions Session[]
  member   Member?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Member {
  id         String   @id @default(cuid())
  userId     String   @unique
  inGameName String
  nickname   String
  role       Role     @default(MEMBER)
  status     Status   @default(PENDING)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id])
  questLogs  QuestLog[]
  warLogs    WarLog[]
  leaveReqs  LeaveRequest[]
  redeemLogs RedeemLog[]
  auditLogs  AuditLog[]     @relation("AuditActor")
}

enum Role {
  GUILD_MASTER
  VICE_MASTER
  MEMBER
}

enum Status {
  PENDING
  ACTIVE
  INACTIVE
}

// ─── Season ───────────────────────────────────────────────────────────────────

model GuildSeason {
  id        String    @id @default(cuid())
  /// Format: "YYYY-MM" เช่น "2026-05" — sort ถูกต้องและ human-readable
  monthYear String    @unique
  isOpen    Boolean   @default(false)
  createdAt DateTime  @default(now())
  closedAt  DateTime?

  questLogs QuestLog[]
  warLogs   WarLog[]
  leaveReqs LeaveRequest[]
  snapshot  SeasonSnapshot?

  // Partial Unique Index สร้างใน migration SQL แยก:
  // CREATE UNIQUE INDEX only_one_open_season ON "GuildSeason" (is_open) WHERE is_open = true;
}

// ─── Quest & War Logs ─────────────────────────────────────────────────────────

model QuestLog {
  id            String      @id @default(cuid())
  memberId      String
  seasonId      String
  date          DateTime    @db.Date
  status        QuestStatus
  proofImageUrl String?
  createdAt     DateTime    @default(now())
  createdBy     String? // admin memberId ที่กดบันทึก

  member Member      @relation(fields: [memberId], references: [id])
  season GuildSeason @relation(fields: [seasonId], references: [id])

  @@unique([memberId, date, seasonId])
}

enum QuestStatus {
  DONE
  ABSENT
  LEAVE
}

model WarLog {
  id        String    @id @default(cuid())
  memberId  String
  seasonId  String
  date      DateTime  @db.Date
  status    WarStatus
  createdAt DateTime  @default(now())

  member Member      @relation(fields: [memberId], references: [id])
  season GuildSeason @relation(fields: [seasonId], references: [id])

  @@unique([memberId, date, seasonId])
}

enum WarStatus {
  ATTENDED
  MISSED
}

// ─── Leave Request ────────────────────────────────────────────────────────────

model LeaveRequest {
  id         String      @id @default(cuid())
  memberId   String
  seasonId   String
  date       DateTime    @db.Date
  reason     String
  status     LeaveStatus @default(PENDING)
  reviewedBy String? // admin memberId
  reviewedAt DateTime?
  createdAt  DateTime    @default(now())

  member Member      @relation(fields: [memberId], references: [id])
  season GuildSeason @relation(fields: [seasonId], references: [id])

  @@unique([memberId, date, seasonId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Shop ─────────────────────────────────────────────────────────────────────

model ShopItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int // points
  stock       Int      @default(0)
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redeemLogs RedeemLog[]
}

model RedeemLog {
  id          String       @id @default(cuid())
  memberId    String
  itemId      String
  pointsSpent Int // snapshot ราคา ณ วันที่ redeem
  status      RedeemStatus @default(PENDING)
  redeemedAt  DateTime     @default(now())
  deliveredAt DateTime?
  deliveredBy String? // admin memberId

  member Member   @relation(fields: [memberId], references: [id])
  item   ShopItem @relation(fields: [itemId], references: [id])
}

enum RedeemStatus {
  PENDING
  DELIVERED
}

// ─── Season Snapshot ──────────────────────────────────────────────────────────

model SeasonSnapshot {
  id        String   @id @default(cuid())
  seasonId  String   @unique
  /// JSON: { mvp, topMembers, stats, perfectAttendance, atRisk }
  data      Json
  createdAt DateTime @default(now())

  season GuildSeason @relation(fields: [seasonId], references: [id])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String // admin memberId ที่ทำ action
  action     String // "APPROVE_MEMBER", "BULK_ABSENT", "UPDATE_LOG", ...
  targetType String // "Member", "QuestLog", "ShopItem", ...
  targetId   String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  actor Member @relation("AuditActor", fields: [actorId], references: [id])
}

// ─── Notification Log ─────────────────────────────────────────────────────────

model NotificationLog {
  id       String   @id @default(cuid())
  memberId String
  type     String // "APPROVED", "WATCHLIST_ALERT", "ITEM_REDEEMABLE"
  payload  Json
  sentAt   DateTime @default(now())
  success  Boolean  @default(true)
}
